SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:3000,http://127.0.0.1:3000

MYSQL_DATABASE=auto_db
MYSQL_USER=auto_user
MYSQL_PASSWORD=auto_password
MYSQL_HOST=db
MYSQL_PORT=3306

REDIS_HOST=redis
REDIS_PORT=6379
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=django-db

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_HOST_USER=example@gmail.com
EMAIL_HOST_PASSWORD=example-password
EMAIL_PORT=587
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=example@gmail.com

ACCOUNT_ACTIVATION_URL_TEMPLATE=http://localhost:8000/api/auth/activate/{token}/
PASSWORD_RECOVERY_URL_TEMPLATE=http://localhost:8000/api/auth/password/reset/{token}/

ACCESS_TOKEN_LIFETIME_MINUTES=15
REFRESH_TOKEN_LIFETIME_DAYS=7
TIME_ZONE=UTC